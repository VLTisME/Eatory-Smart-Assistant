# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# PostgreSQL used by maps-scraper and some local pipelines
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maps_reviews"

# Optional local dataset paths
KAGGLEHUB_CACHE="./kaggle_cache"
KAGGLE_ARCHIVE_PATH="./data/raw/1.archive"
KAGGLE_DATASET_DIR="./data/raw/tdtt-ver2"
KAGGLE_PLACES_FILE="places.json"
KAGGLE_REVIEWS_FILE="clean_reviews.json"

# Cloudinary/image ingestion
LOCAL_IMAGES_ROOT="./data/raw/tdtt-ver2"
LOCAL_IMAGES_SUBDIR="images"
CLOUDINARY_ROOT_FOLDER="smart_tourism"
CLOUDINARY_UPLOAD_WORKERS=8
CLOUDINARY_MAX_RETRIES=3
CLOUDINARY_CHECKPOINT_FILE="./artifacts/cloudinary_results.json"
CLOUDINARY_CHECKPOINT_INTERVAL=50
MAX_IMAGE_FILE_MB=25

# Embedding and summary publishing
EMBEDDINGS_ARTIFACT_DIR="./artifacts"
IMAGE_INDEX_FILE="image_index.json"
IMAGE_EMBEDDINGS_FILE="image_embeddings.npy"
EMBEDDING_CHECKPOINT_FILE="./artifacts/embedding_checkpoint.json"
REVIEW_SUMMARIES_FILE="./artifacts/review_summaries_with_text.json"

# Batch tuning
PLACES_BATCH_SIZE=200
REVIEWS_BATCH_SIZE=500
EMBEDDINGS_BATCH_SIZE=50
SUMMARIES_BATCH_SIZE=200
SUPABASE_BATCH_SIZE=100
SUPABASE_PAGE_SIZE=1000
SUPABASE_DELAY_SECONDS=0.3
MAX_REVIEW_LENGTH=2000

# Local tooling ports
MAPS_SCRAPER_HOST="localhost"
MAPS_SCRAPER_PORT=8201
DE_IMAGE_TOOLING_HOST="127.0.0.1"
DE_IMAGE_TOOLING_PORT=8202
