# App
APP_NAME="Place Search AI Service"
APP_VERSION="0.1.0"
SERVICE_HOST="0.0.0.0"
SERVICE_PORT=8102
SERVICE_DEBUG=false
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS='["http://localhost:8000"]'

# Optional service-to-service bearer token.
# If set here, backend AI_SERVICE_TOKEN must match this value.
SERVICE_TOKEN=""

# Upload validation
MAX_UPLOAD_SIZE_MB=10

# Root data/ artifacts are intentionally kept in place during Phase 3.
PLACE_SEARCH_EMBEDDINGS_PATH="data/image_embeddings.npy"
PLACE_SEARCH_INDEX_PATH="data/image_index.json"
PLACE_SEARCH_PLACES_PATH="data/places.json"
PLACE_SEARCH_NOISE_EMBEDDINGS_PATH="data/noise_embeddings.npy"
PLACE_SEARCH_NOISE_INDEX_PATH="data/noise_index.json"
PLACE_SEARCH_NOISE_THRESHOLD=0.73
PLACE_SEARCH_MODEL_NAME="laion/CLIP-ViT-H-14-laion2B-s32B-b79K"
PLACE_SEARCH_TOP_K_IMAGES=5
PLACE_SEARCH_MIN_SIMILARITY=0.0
PLACE_SEARCH_USE_GPU=false

# Optional: improves Hugging Face rate limits for CLIP model downloads.
HF_TOKEN=""
HF_HUB_DISABLE_XET=1

# Place metadata enrichment. If unavailable, the service falls back to PLACE_SEARCH_PLACES_PATH.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Optional place-search response refinement
OPENAI_API_KEY="your-openai-api-key"
OPENAI_REFINE_MODEL="gpt-4o-mini"
