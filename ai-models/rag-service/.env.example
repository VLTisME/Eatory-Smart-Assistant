APP_NAME="RAG AI Service"
APP_VERSION="0.1.0"
SERVICE_HOST="0.0.0.0"
SERVICE_PORT=8103
SERVICE_DEBUG=false
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS='["http://localhost:8000"]'
SERVICE_TOKEN=""

OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_REFINE_MODEL="gpt-4o-mini"

RAG_COLLECTION_NAME="places_rag"
RAG_CHROMA_DIR="./chroma_db"
RAG_EMBEDDING_MODEL="AITeamVN/Vietnamese_Embedding"
RAG_EMBEDDING_DEVICE="cpu"
RAG_NO_RESULTS_MESSAGE="Mình chưa tìm thấy địa điểm phù hợp trong dữ liệu hiện tại."

# Optional: improves Hugging Face rate limits for embedding model downloads.
HF_TOKEN=""
HF_HUB_DISABLE_XET=1
