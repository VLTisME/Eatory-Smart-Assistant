# App
APP_NAME="Review Summary AI Service"
APP_VERSION="0.1.0"
SERVICE_HOST="0.0.0.0"
SERVICE_PORT=8104
SERVICE_DEBUG=false
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS='["http://localhost:8000"]'

# Optional service-to-service bearer token.
# If set here, backend AI_SERVICE_TOKEN must match this value.
SERVICE_TOKEN=""

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_REFINE_MODEL="gpt-4o-mini"

# Offline pipeline
# Used by scripts under ai-models/review-summary-service/offline/.
# The scripts load this root .env first, then offline/.env if present.
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/review_summary_db"
