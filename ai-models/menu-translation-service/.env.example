# App
APP_NAME="Menu Translation AI Service"
APP_VERSION="0.1.0"
SERVICE_HOST="0.0.0.0"
SERVICE_PORT=8101
SERVICE_DEBUG=false
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS='["http://localhost:8000"]'

# Optional service-to-service bearer token.
# If set here, backend AI_SERVICE_TOKEN must match this value.
SERVICE_TOKEN=""

# Upload validation
MAX_UPLOAD_SIZE_MB=10

# OCR and menu structuring
OCR_PROVIDER="openai"
OCR_LANGUAGES="vi,en"
OCR_GPU=false
OCR_OPENAI_MODEL="gpt-4o-mini"
MENU_REFINE_MAX_CHARS=8000

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_REFINE_MODEL="gpt-4o-mini"
