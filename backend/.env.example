# App
APP_NAME="Smart Travel Assistant API"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
SERVICE_HOST="0.0.0.0"
SERVICE_PORT=8000
SERVICE_DEBUG=false
LOG_LEVEL="INFO"
CORS_ALLOW_ORIGINS='["http://localhost:5173"]'

# Upload validation
MAX_UPLOAD_SIZE_MB=10

# Auth
FIREBASE_SERVICE_ACCOUNT_PATH="firebase-service-account.json"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Goong REST APIs
REST_API_KEY="your-goong-rest-api-key"

# ImageKit
KIT_URL_ENDPOINT="https://ik.imagekit.io/your-imagekit-id"
KIT_PUBLIC_KEY="your-imagekit-public-key"
KIT_PRIVATE_KEY="your-imagekit-private-key"

REVIEW_SUMMARY_PATH="../ai-models/review-summary-service/offline/data/output/review_summaries.json"

# Internal AI service URLs
AI_MENU_SERVICE_URL="http://localhost:8101"
AI_PLACE_SEARCH_SERVICE_URL="http://localhost:8102"
AI_RAG_SERVICE_URL="http://localhost:8103"
AI_REFINEMENT_SERVICE_URL="http://localhost:8103"
AI_REVIEW_SUMMARY_SERVICE_URL="http://localhost:8104"
AI_SERVICE_TIMEOUT_SECONDS=180
AI_SERVICE_TOKEN=""
